FROM node:20-slim

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

ARG NEXT_PUBLIC_API_BASE=http://localhost:3100
ARG NEXT_PUBLIC_ENGINE_BASE=http://localhost:3200
ENV NEXT_PUBLIC_API_BASE=${NEXT_PUBLIC_API_BASE}
ENV NEXT_PUBLIC_ENGINE_BASE=${NEXT_PUBLIC_ENGINE_BASE}

RUN npm run build

EXPOSE 3000

CMD ["npm", "start"]
